# RidePod payment provider.
# MOCK is the default and keeps all money movement local/mock.
# STRIPE_TEST is for future Stripe test-mode slices only.
PAYMENT_PROVIDER=MOCK

# Stripe test-mode keys only. Do not use sk_live_ or pk_live_ keys.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Reserved for a future webhook slice.
STRIPE_WEBHOOK_SECRET=

# Supabase MVP data layer. Public values are safe for browser clients.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_RIDEPOD_USE_SUPABASE_STORAGE=false

# Mapbox public browser token for create-flow live route preview.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Server-only. Never expose this value to browser/client code.
SUPABASE_SERVICE_ROLE_KEY=
